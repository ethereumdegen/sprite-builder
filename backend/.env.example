# --- server ---
BIND_ADDR=0.0.0.0:8787
# In local dev the Vite frontend proxies /api to the backend, so the browser
# only ever talks to :5173 (same-origin -> session cookies just work).
# Set BACKEND_URL to the origin the BROWSER hits (5173 in dev), NOT :8787.
# In production set both to your real public https origins.
BACKEND_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# --- NeonDB (Postgres) ---
# Get this from your Neon project dashboard. sslmode=require is recommended.
DATABASE_URL=postgres://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# --- GitHub OAuth App (server only; the worker ignores these) ---
# Create at https://github.com/settings/developers
# Authorization callback URL must be: <BACKEND_URL>/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- sprites.dev ---
# Token from https://sprites.dev/account (or `sprite org auth`)
SPRITES_TOKEN=your_sprites_token
# Your sprites org slug, used to build the public URL: https://<sprite>-<org>.sprites.dev
SPRITES_ORG=your_org_slug

# --- worker ---
WORKER_POLL_SECS=5

# --- misc ---
DB_MAX_CONNECTIONS=10
# Directory of built frontend assets for the API server to serve (production).
# Leave empty in local dev (Vite serves the frontend). In Docker this is set to /app/static.
STATIC_DIR=
