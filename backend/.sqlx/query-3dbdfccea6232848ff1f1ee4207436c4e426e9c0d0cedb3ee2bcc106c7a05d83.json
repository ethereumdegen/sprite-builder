  "query": "SELECT u.id, u.github_id, u.github_login, u.name, u.avatar_url,\n                              u.github_token, u.created_at, u.updated_at, u.role\n                       FROM users u\n                       JOIN api_keys k ON k.user_id = u.id\n                       WHERE k.key_hash = $1",
